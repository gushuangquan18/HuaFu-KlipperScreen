{
  "father":"menu",
  "name":"home_menu",
  "type":"Grid",
  "children":{
    "up_grid":{
      "name":"Up Grid",
      "name":"Up Grid",
      "type":"Grid",
      "width":900,
      "height":310,
      "column":0,
      "row":0,
      "columnspan":1,
      "rowspan":1,
      "row_spacing": 15,
      "column_spacing": 10,
      "children":{
        "printer":{
          "name":"3D Printer Model",
          "type":"Image",
          "width":270,
          "height":270,
          "column":0,
          "row":0,
          "columnspan":1,
          "rowspan":1,
          "src":"images/3D_printer.png"
        },
        "tag_blue":{
          "name":"Tag Blue",
          "type":"Image",
          "width":6,
          "height":40,
          "column":1,
          "row":0,
          "columnspan":1,
          "rowspan":1,
          "src":"images/tag_blue.png"
        },
        "interactive_message":{
          "name":"Interactive Message",
          "type":"Label",
          "column":2,
          "row":0,
          "columnspan":1,
          "rowspan":1,
          "value":"Today is another wonderful day!"
        }
      }
    },
    "down_grid":{
      "name":"Down Grid",
      "type":"Grid",
      "width":900,
      "height":210,
      "column":0,
      "row":1,
      "columnspan":1,
      "rowspan":1,
      "children":{
        "print_file_list":{
          "name":"Print File List",
          "type":"Button",
          "connect":"clicked",
          "method":"go_to_next_interface",
          "panel":"print_file_list",
          "column":0,
          "row":0,
          "columnspan":1,
          "rowspan":1,
          "print_file_list_grid":{
            "name":"Print File List Grid",
            "type":"Grid",
            "column":0,
            "row":0,
            "columnspan":1,
            "rowspan":1,
            "width": 400,
            "height": 190,
            "column_spacing":1,
            "children": {
              "modeling_graphics":{
                "name":"Modeling Graphics",
                "type":"Image",
                "width":150,
                "height":150,
                "column":0,
                "row":0,
                "columnspan":1,
                "rowspan":1,
                "src":"images/home_modeling_graphics.png"
              },
              "print_file_label":{
                "name":"Print File Label",
                "type":"Label",
                "column":1,
                "row":0,
                "columnspan":1,
                "rowspan":1,
                "value":"打印文件"
              }
            }
          }
        },
        "lower_right_grid":{
          "name":"Lower_Right_Grid",
          "type":"Grid",
          "column":1,
          "row":0,
          "columnspan":1,
          "rowspan":1,
          "width": 500,
          "height": 190,
          "nozzle_extruder":{
              "name":"Nozzle Extruder",
              "type":"Button",
              "connect":"clicked",
              "panel":"printer_control_menu",
              "column":0,
              "row":0,
              "columnspan":1,
              "rowspan":1,
              "style":"home_menu_button",
              "nozzle_extruder_grid":{
                "name":"Nozzle Extruder Grid",
                "type":"Grid",
                "column":0,
                "row":0,
                "columnspan":1,
                "rowspan":1,
                "width": 100,
                "height": 190,
                "column_homogeneous": "True",
                "children": {
                  "nozzle1_icon":{
                    "name":"Nozzle1 Icon",
                    "type":"Image",
                    "width":50,
                    "height":50,
                    "column":0,
                    "row":0,
                    "columnspan":1,
                    "rowspan":1,
                    "src":"images/nozzle.png"
                  },
                  "nozzle1_temperature_label":{
                    "name":"Nozzle1 Temperature",
                    "type":"Label",
                    "value":"25℃",
                    "column":0,
                    "row":1,
                    "columnspan":1,
                    "rowspan":1
                  },
                    "nozzle2_icon":{
                    "name":"Nozzle2 Icon",
                    "type":"Image",
                    "width":50,
                    "height":50,
                    "src":"images/nozzle.png",
                    "column":0,
                    "row":2,
                    "columnspan":1,
                    "rowspan":1
                  },
                  "nozzle2_temperature_label":{
                    "name":"Nozzle2 Temperature",
                    "type":"Label",
                    "value":"25℃",
                    "column":0,
                    "row":3,
                    "columnspan":1,
                    "rowspan":1
                  }
                }
            }
          },
          "wifi":{
            "name":"WIFI",
            "type":"Button",
            "panel":"wifi",
            "icon": "wifi",
            "value": "WiFi",
            "connect":"clicked",
            "column":1,
            "row":0,
            "columnspan":1,
            "rowspan":1,
            "width": 60,
            "height": 60,
            "style":"home_menu_button"
          },
          "messages_assistant":{
            "name":"Messages Assistant",
            "type":"Button",
            "icon":"messages_assistant",
            "panel":"messages_menu",
            "column":2,
            "row":0,
            "columnspan":1  ,
            "rowspan":1,
            "width": 55,
            "height": 55,
            "style":"home_menu_button"
          }
        }
      }
    }
  }
}
