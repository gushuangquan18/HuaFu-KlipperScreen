{
  "father":"select_disc_print",
  "name":"matching_consumables",
  "type":"Grid",
  "head_box":{
    "name":"Head Box",
    "type":"Box",
    "children":{
      "go_bcak":{
        "name":"Go Back",
        "type":"Button",
        "src":"images/back.svg",
        "connect":"clicked",
