      },
      "matching_consumables_label":{
        "name":"Matching Consumables",
        "type":"Label",
        "value":"匹配耗材"
      },
      "print":{
        "name":"Print",
        "type":"Button",
        "panel":"Print",
        "connect":"clicked",
        "method":"TODO"
      }
    }
  },
  "details":{
    "name":"Details",
    "type":"Grid",
